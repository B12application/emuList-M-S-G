rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow a signed-in user to read/write files under their own user folder
    match /users/{userId}/vehicles/{vehicleId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny write to any other paths by default; allow read for public media if desired
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
