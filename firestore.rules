rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerByResource() {
      return isSignedIn() && resource.data.userId is string && request.auth.uid == resource.data.userId;
    }

    function isOwnerByRequest() {
      return isSignedIn() && request.resource.data.userId is string && request.auth.uid == request.resource.data.userId;
    }

    function isLegacyWithoutUserId() {
      return !(resource.data.userId is string);
    }

    // AI Usage tracking - Needed for serverless functions
    match /ai_usage/{date} {
      allow read, write: if true; // Public access for limit tracking
    }

    // Media Items
    match /mediaItems/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User Profiles
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Recommendations
    match /recommendations/{recId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == 'ZKU7SObBkeNzMicltUKJjo6ybHH2';
    }
    
    // Activities
    match /activities/{activityId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        resource.data.timestamp < request.time - duration.value(10, 'd')
      );
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.recipientId;
      allow create: if request.auth != null;
      allow update,delete: if request.auth != null && request.auth.uid == resource.data.recipientId;
    }
    
    // Activity Likes
    match /activityLikes/{likeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null;
    }
    
    // Activity Comments
    match /activityComments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null;
    }
    
    // Custom Lists
    match /customLists/{listId} {
      allow read: if request.auth != null && (resource.data.isPublic == true || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Planner Meetings
    match /meetings/{meetingId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Calendar Alerts
    match /calendarAlerts/{alertId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isOwnerByResource() || (isSignedIn() && isLegacyWithoutUserId());
      allow update: if isOwnerByResource() || (isLegacyWithoutUserId() && isOwnerByRequest());
      allow delete: if isOwnerByResource() || (isSignedIn() && isLegacyWithoutUserId());
      allow create: if isOwnerByRequest();
    }

    // ExpenseData (Transactions)
    match /expensedata/{expenseId} {
      allow read: if isOwnerByResource() || (isSignedIn() && isLegacyWithoutUserId());
      allow update: if isOwnerByResource() || (isLegacyWithoutUserId() && isOwnerByRequest());
      allow delete: if isOwnerByResource() || (isSignedIn() && isLegacyWithoutUserId());
      allow create: if isOwnerByRequest();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if isOwnerByResource() || (isSignedIn() && isLegacyWithoutUserId());
      allow update: if isOwnerByResource() || (isLegacyWithoutUserId() && isOwnerByRequest());
      allow delete: if isOwnerByResource() || (isSignedIn() && isLegacyWithoutUserId());
      allow create: if isOwnerByRequest();
    }

    // Vehicles
    match /vehicles/{vehicleId} {
      allow read, delete: if isOwnerByResource();
      allow update: if isOwnerByResource() || isOwnerByRequest();
      allow create: if isOwnerByRequest();
    }

    // Vehicle Logs
    match /vehicle_logs/{logId} {
      allow read, delete: if isOwnerByResource();
      allow update: if isOwnerByResource() || isOwnerByRequest();
      allow create: if isOwnerByRequest();
    }

    // Vehicle Maintenance
    match /vehicle_maintenance/{maintenanceId} {
      allow read, delete: if isOwnerByResource();
      allow update: if isOwnerByResource() || isOwnerByRequest();
      allow create: if isOwnerByRequest();
    }

    // Investments
    match /investments/{investmentId} {
      allow read, delete, update: if isOwnerByResource();
      allow create: if isOwnerByRequest();
    }

    // Invoice Subscriptions (Fatura & Abonelikler)
    match /invoiceSubscriptions/{subscriptionId} {
      allow read, delete, update: if isOwnerByResource();
      allow create: if isOwnerByRequest();
    }
    // Budget Plans
    match /budgetPlans/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}